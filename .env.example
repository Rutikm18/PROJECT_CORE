# =============================================================================
#  .env.example — Manager environment variables
#
#  Usage:
#    cp .env.example .env
#    # Fill in API_KEY, update paths as needed
#    # Load before starting the manager:
#    #   export $(grep -v '^#' .env | xargs)
#
#  NEVER commit .env to version control — it contains secrets.
#  .env is in .gitignore.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# 256-bit master API key shared between agent and manager.
# Generate a new one: python3 scripts/keygen.py
API_KEY=REPLACE_WITH_OUTPUT_OF_KEYGEN

# ── Network ───────────────────────────────────────────────────────────────────

BIND_HOST=0.0.0.0
BIND_PORT=8443

# ── TLS ───────────────────────────────────────────────────────────────────────
# Leave blank to run without TLS (use a reverse proxy like nginx or Caddy).
# For dev: make certs  (generates self-signed cert in certs/)

TLS_CERT=certs/server.crt
TLS_KEY=certs/server.key

# ── Storage ───────────────────────────────────────────────────────────────────
# Default: manager/data/manager.db
# DB_PATH=/var/lib/mac-intel/manager.db

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Use specific domains in production (never * in prod).
CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
