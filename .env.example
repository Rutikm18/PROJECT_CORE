# =============================================================================
#  .env.example — Jarvis Manager environment variables
#
#  DO NOT edit this file directly.
#  Run env.sh to generate a real .env with auto-detected values and secrets:
#
#    bash env.sh
#
#  env.sh will:
#    • Detect your public IP automatically
#    • Ask if you have a domain (Let's Encrypt) or want IP-only (self-signed)
#    • Ask whether enrollment requires a token
#    • Generate ADMIN_TOKEN and ENROLLMENT_TOKENS
#    • Write .env and Caddyfile ready for docker compose up
#
#  NEVER commit .env to version control — it contains secrets.
# =============================================================================

# ── Network ───────────────────────────────────────────────────────────────────

# Server's public IP (auto-detected by env.sh)
PUBLIC_IP=

# Domain name (optional — only needed for Let's Encrypt TLS)
DOMAIN=

# Port Caddy listens on:
#   8443 → self-signed cert (IP-only mode, no domain)
#   443  → Let's Encrypt cert (domain mode)
BIND_PORT=8443

# Admin email for Let's Encrypt (only needed when DOMAIN is set)
ADMIN_EMAIL=

# ── TLS mode ──────────────────────────────────────────────────────────────────
# self-signed = Caddy internal CA  (IP-only, agents set tls_verify = false)
# letsencrypt = Let's Encrypt      (domain required, agents set tls_verify = true)
TLS_MODE=self-signed

# ── Auth ──────────────────────────────────────────────────────────────────────

# Admin token — protects key management API (/api/v1/keys/*)
# Generated by env.sh. Format: sk-admin-<random>
ADMIN_TOKEN=

# Enrollment mode:
#   true  = any agent can connect (recommended for single operator)
#   false = agents must supply ENROLLMENT_TOKENS to register
OPEN_ENROLLMENT=true

# Enrollment token (only checked when OPEN_ENROLLMENT=false)
# Generated by env.sh. Format: sk-enroll-<random>
ENROLLMENT_TOKENS=

# ── Key Policy ────────────────────────────────────────────────────────────────

# Days until agent API keys expire. 0 = never expire.
DEFAULT_KEY_EXPIRY_DAYS=0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Threat Intel API Keys (all optional — feeds degrade gracefully) ────────────
# AbuseIPDB — IP reputation scoring (https://www.abuseipdb.com/api)
ABUSEIPDB_KEY=

# OTX AlienVault — IP/domain threat intel (https://otx.alienvault.com)
OTX_KEY=

# GreyNoise Community — scanner/noise detection (https://www.greynoise.io)
GREYNOISE_KEY=

# ── AI Analyst (Claude API) ────────────────────────────────────────────────────
# Anthropic API key — powers AI analysis and remediation generation
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model to use (default: claude-sonnet-4-6)
AI_ANALYST_MODEL=claude-sonnet-4-6

# Set to "false" to disable AI features (feeds, scoring, and alerts still work)
AI_ANALYST_ENABLED=true

# ── Email Notifications ────────────────────────────────────────────────────────
# SMTP (generic — works with Office 365, Gmail, Exchange, Postfix, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AttackLens Alerts <alerts@yourorg.com>
# "starttls" (port 587), "ssl" (port 465), or "none"
SMTP_TLS=starttls

# Microsoft Graph API (Office 365 OAuth — alternative to SMTP)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_SENDER=

# Comma-separated recipient lists
ALERT_RECIPIENTS=
DIGEST_RECIPIENTS=

# Set "false" to disable all email notifications
EMAIL_ENABLED=true

# ── Threat Feed Intervals ──────────────────────────────────────────────────────
THREAT_FEED_INTERVAL_SECONDS=3600
NVD_SYNC_INTERVAL_SECONDS=7200
NVD_SYNC_HOURS=48
NVD_SYNC_MAX_PAGES=3
