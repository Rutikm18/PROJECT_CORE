# =============================================================================
#  .env.example — Jarvis Manager environment variables
#
#  Copy to .env and fill in your values:
#    cp .env.example .env
#
#  docker compose automatically loads .env from the same directory.
#  NEVER commit .env to version control — it contains secrets.
# =============================================================================

# ── Network ───────────────────────────────────────────────────────────────────

# Your server's public IP address.
# Run: export PUBLIC_IP=$(curl -s https://api.ipify.org)
PUBLIC_IP=

# Your domain name (optional — for Let's Encrypt TLS via docker-compose.prod.yml)
DOMAIN=

# Port the manager listens on (default: 8443 for direct TLS, 8080 behind proxy)
BIND_PORT=8443

# ── Auth ──────────────────────────────────────────────────────────────────────

# Enrollment token — agents need this to register for the first time.
# Comma-separated for multiple tokens (e.g. one per team).
# Leave blank to auto-generate on first boot (tokens printed in docker logs).
ENROLLMENT_TOKENS=

# Admin token — protects the key management API (/api/v1/keys/*).
# Leave blank to auto-generate on first boot (printed in docker logs).
ADMIN_TOKEN=

# ── Key Policy ────────────────────────────────────────────────────────────────

# Default number of days before a newly enrolled agent key expires.
# 0 = keys never expire.
DEFAULT_KEY_EXPIRY_DAYS=0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Let's Encrypt (docker-compose.prod.yml only) ─────────────────────────────
ADMIN_EMAIL=admin@example.com
