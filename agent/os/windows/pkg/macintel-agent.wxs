<?xml version="1.0" encoding="UTF-8"?>
<!--
  macintel-agent.wxs — WiX v4 MSI definition for mac_intel Windows Agent
  =========================================================================
  Build with:
    wix build macintel-agent.wxs -o macintel-agent.msi              (WiX v4)
  or:
    candle macintel-agent.wxs -ext WixUtilExtension                 (WiX v3)
    light  macintel-agent.wixobj -ext WixUtilExtension -o macintel-agent.msi

  Required build-time variables (pass via -d on wix/candle CLI):
    -d AgentExe=dist\macintel-agent.exe
    -d WatchdogExe=dist\macintel-watchdog.exe
    -d Version=1.0.0
    -d GenerateConfigScript=generate_config.ps1

  MSI properties set at install time (msiexec /property=VALUE):
    MANAGER_URL       — https://manager-host:8443
    ENROLL_TOKEN      — sk-enroll-<hex>     (or empty to use api_key)
    MANAGER_API_KEY   — 64-hex key          (alternative to ENROLL_TOKEN)
    AGENT_ID          — unique agent identifier (default: generated UUID)
    AGENT_NAME        — human-readable label
    TLS_VERIFY        — true / false
    INSTALL_DIR       — default C:\Program Files\MacIntel
    DATA_DIR          — default C:\ProgramData\MacIntel

  Silent install example:
    msiexec /i macintel-agent.msi /qn ^
      MANAGER_URL="https://manager.corp.example:8443" ^
      ENROLL_TOKEN="sk-enroll-abc123" ^
      AGENT_NAME="WORKSTATION-01" ^
      TLS_VERIFY="true"
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- ═══════════════════════════════════════════════════════════════════════
       Product metadata
       ═══════════════════════════════════════════════════════════════════════ -->
  <Package
    Name="mac_intel Agent"
    Manufacturer="mac_intel"
    Version="$(var.Version)"
    UpgradeCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perMachine">

    <SummaryInformation
      Keywords="mac_intel agent endpoint telemetry"
      Description="mac_intel Endpoint Agent for Windows"
      Manufacturer="mac_intel"
      Comments="Collects system telemetry and sends to mac_intel Manager" />

    <!-- ── Upgrade policy: replace older versions, block downgrades ──── -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of mac_intel Agent is already installed."
      AllowSameVersionUpgrades="yes"
      Schedule="afterInstallInitialize" />

    <!-- ── Media / cabinet ─────────────────────────────────────────────── -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- ════════════════════════════════════════════════════════════════════
         MSI Properties
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Install locations -->
    <Property Id="INSTALL_DIR"     Value="[ProgramFiles64Folder]MacIntel" />
    <Property Id="DATA_DIR"        Value="[CommonAppDataFolder]MacIntel" />

    <!-- Connection settings -->
    <Property Id="MANAGER_URL"     Value="" />
    <Property Id="ENROLL_TOKEN"    Value="" />
    <Property Id="MANAGER_API_KEY" Value="" />
    <Property Id="TLS_VERIFY"      Value="true" />

    <!-- Agent identity -->
    <Property Id="AGENT_ID"   Value="" />
    <Property Id="AGENT_NAME" Value="" />

    <!-- Internal: set by MSI, used by custom action -->
    <Property Id="POWERSHELLEXE">
      <RegistrySearch Id="FindPS"
        Root="HKLM"
        Key="SOFTWARE\Microsoft\PowerShell\3\PowerShellEngine"
        Name="ApplicationBase"
        Type="directory" />
    </Property>

    <!-- ════════════════════════════════════════════════════════════════════
         Directory structure
         ════════════════════════════════════════════════════════════════════ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="MacIntel">
        <Directory Id="BINDIR"      Name="bin" />
        <Directory Id="SCRIPTSDIR"  Name="scripts" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATADIR" Name="MacIntel">
        <Directory Id="LOGDIR"      Name="logs" />
        <Directory Id="SECURITYDIR" Name="security" />
        <Directory Id="DATASUBDIR"  Name="data" />
      </Directory>
    </StandardDirectory>

    <!-- ════════════════════════════════════════════════════════════════════
         Components
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ── Agent EXE ──────────────────────────────────────────────────── -->
    <Component Id="CmpAgentExe" Directory="BINDIR" Guid="{B1C2D3E4-F5A6-7890-BCDE-F12345678901}">
      <File Id="AgentExe"
        Name="macintel-agent.exe"
        Source="$(var.AgentExe)"
        KeyPath="yes" />

      <!-- Windows Service registration -->
      <ServiceInstall
        Id="SvcInstallAgent"
        Name="MacIntelAgent"
        DisplayName="mac_intel Agent"
        Description="Collects system telemetry and sends encrypted data to mac_intel Manager."
        Type="ownProcess"
        Start="auto"
        ErrorControl="normal"
        Account="LocalSystem"
        Arguments="--config &quot;[DATADIR]agent.toml&quot;"
        Vital="yes">
        <!-- Depend on network stack -->
        <util:ServiceConfig
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          RestartServiceDelayInSeconds="10"
          ResetPeriodInDays="1" />
        <ServiceDependency Id="Tcpip" />
        <ServiceDependency Id="Dnscache" />
      </ServiceInstall>

      <ServiceControl
        Id="SvcCtrlAgentStop"
        Name="MacIntelAgent"
        Stop="both"
        Remove="uninstall"
        Wait="yes" />

      <ServiceControl
        Id="SvcCtrlAgentStart"
        Name="MacIntelAgent"
        Start="install"
        Wait="no" />
    </Component>

    <!-- ── Watchdog EXE ───────────────────────────────────────────────── -->
    <Component Id="CmpWatchdogExe" Directory="BINDIR" Guid="{C2D3E4F5-A6B7-8901-CDEF-123456789012}">
      <File Id="WatchdogExe"
        Name="macintel-watchdog.exe"
        Source="$(var.WatchdogExe)"
        KeyPath="yes" />

      <ServiceInstall
        Id="SvcInstallWatchdog"
        Name="MacIntelWatchdog"
        DisplayName="mac_intel Watchdog"
        Description="Monitors and restarts the mac_intel Agent service."
        Type="ownProcess"
        Start="auto"
        ErrorControl="normal"
        Account="LocalSystem"
        Vital="no">
        <util:ServiceConfig
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          RestartServiceDelayInSeconds="30"
          ResetPeriodInDays="1" />
        <ServiceDependency Id="MacIntelAgent" />
      </ServiceInstall>

      <ServiceControl
        Id="SvcCtrlWatchdogStop"
        Name="MacIntelWatchdog"
        Stop="both"
        Remove="uninstall"
        Wait="yes" />

      <ServiceControl
        Id="SvcCtrlWatchdogStart"
        Name="MacIntelWatchdog"
        Start="install"
        Wait="no" />
    </Component>

    <!-- ── Config-generator PowerShell script ────────────────────────── -->
    <Component Id="CmpGenerateConfig" Directory="SCRIPTSDIR" Guid="{D3E4F5A6-B7C8-9012-DEF0-234567890123}">
      <File Id="GenerateConfigScript"
        Name="generate_config.ps1"
        Source="$(var.GenerateConfigScript)"
        KeyPath="yes" />
    </Component>

    <!-- ── Data directories (creates them, sets ownership) ───────────── -->
    <Component Id="CmpDataDir" Directory="DATADIR" Guid="{E4F5A6B7-C8D9-0123-EF01-345678901234}">
      <CreateFolder Directory="DATADIR">
        <util:PermissionEx
          User="SYSTEM"
          GenericAll="yes" />
        <util:PermissionEx
          User="Administrators"
          GenericAll="yes" />
      </CreateFolder>
      <KeyPath>
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\MacIntel\Agent"
          Name="DataDir"
          Value="[DATADIR]"
          Type="string" />
      </KeyPath>
    </Component>

    <Component Id="CmpLogDir" Directory="LOGDIR" Guid="{F5A6B7C8-D9E0-1234-F012-456789012345}">
      <CreateFolder />
      <RemoveFolder Id="RemoveLogDir" Directory="LOGDIR" On="uninstall" />
    </Component>

    <Component Id="CmpSecurityDir" Directory="SECURITYDIR" Guid="{A6B7C8D9-E0F1-2345-0123-567890123456}">
      <CreateFolder Directory="SECURITYDIR">
        <!-- Restrict security dir: SYSTEM + Administrators only -->
        <util:PermissionEx
          User="SYSTEM"
          GenericAll="yes" />
        <util:PermissionEx
          User="Administrators"
          GenericAll="yes" />
      </CreateFolder>
      <RemoveFolder Id="RemoveSecurityDir" Directory="SECURITYDIR" On="uninstall" />
    </Component>

    <!-- ── Registry: install path + version ──────────────────────────── -->
    <Component Id="CmpRegistry" Directory="INSTALLDIR" Guid="{B7C8D9E0-F1A2-3456-1234-678901234567}">
      <RegistryValue
        Root="HKLM"
        Key="SOFTWARE\MacIntel\Agent"
        Name="InstallDir"
        Value="[INSTALLDIR]"
        Type="string"
        KeyPath="yes" />
      <RegistryValue
        Root="HKLM"
        Key="SOFTWARE\MacIntel\Agent"
        Name="Version"
        Value="$(var.Version)"
        Type="string" />
      <RegistryValue
        Root="HKLM"
        Key="SOFTWARE\MacIntel\Agent"
        Name="ConfigFile"
        Value="[DATADIR]agent.toml"
        Type="string" />
    </Component>

    <!-- ── Event log source registration ─────────────────────────────── -->
    <Component Id="CmpEventLog" Directory="INSTALLDIR" Guid="{C8D9E0F1-A2B3-4567-2345-789012345678}">
      <util:EventSource
        Log="Application"
        Name="MacIntelAgent"
        EventMessageFile="[SystemFolder]EventCreate.exe" />
    </Component>

    <!-- ════════════════════════════════════════════════════════════════════
         Feature: single installable unit
         ════════════════════════════════════════════════════════════════════ -->
    <Feature Id="FeatureComplete" Title="mac_intel Agent" Level="1" AllowAdvertise="no">
      <ComponentRef Id="CmpAgentExe" />
      <ComponentRef Id="CmpWatchdogExe" />
      <ComponentRef Id="CmpGenerateConfig" />
      <ComponentRef Id="CmpDataDir" />
      <ComponentRef Id="CmpLogDir" />
      <ComponentRef Id="CmpSecurityDir" />
      <ComponentRef Id="CmpRegistry" />
      <ComponentRef Id="CmpEventLog" />
    </Feature>

    <!-- ════════════════════════════════════════════════════════════════════
         Custom Actions
         ════════════════════════════════════════════════════════════════════ -->

    <!--
      CA: Write agent.toml from MSI properties.
      Runs as deferred in-system context so it can write to ProgramData.
      The script receives properties via CustomActionData (semicolon-delimited).
    -->
    <SetProperty
      Id="CA_WriteConfig"
      Value="INSTALL_DIR=[INSTALLDIR];DATA_DIR=[DATADIR];LOG_DIR=[DATADIR]logs;SECURITY_DIR=[DATADIR]security;MANAGER_URL=[MANAGER_URL];ENROLL_TOKEN=[ENROLL_TOKEN];MANAGER_API_KEY=[MANAGER_API_KEY];AGENT_ID=[AGENT_ID];AGENT_NAME=[AGENT_NAME];TLS_VERIFY=[TLS_VERIFY]"
      Sequence="execute"
      Before="CA_WriteConfig_Deferred" />

    <CustomAction
      Id="CA_WriteConfig_Deferred"
      Script="jscript"
      Execute="deferred"
      Return="check"
      Impersonate="no">
      <![CDATA[
        // Parse CustomActionData key=value pairs
        var data = Session.Property("CustomActionData");
        var props = {};
        data.split(";").forEach(function(pair) {
            var idx = pair.indexOf("=");
            if (idx > 0) props[pair.slice(0, idx)] = pair.slice(idx + 1);
        });

        function p(key, def) {
            var v = props[key];
            return (v && v.length > 0) ? v : (def || "");
        }

        // Generate a UUID-style agent ID if not provided
        var agentId = p("AGENT_ID");
        if (!agentId) {
            // Simple pseudo-UUID using WSH (no crypto needed — just needs to be unique)
            var shell = new ActiveXObject("WScript.Shell");
            try {
                var typelib = new ActiveXObject("Scriptlet.TypeLib");
                agentId = typelib.Guid.slice(1, -1).toLowerCase();
            } catch(e) {
                // Fallback: timestamp-based ID
                agentId = "agent-win-" + (new Date()).getTime().toString(16);
            }
        }

        var agentName = p("AGENT_NAME");
        if (!agentName) {
            try {
                var netInfo = new ActiveXObject("WScript.Network");
                agentName = netInfo.ComputerName;
            } catch(e) {
                agentName = agentId;
            }
        }

        var dataDir     = p("DATA_DIR",     "C:\\ProgramData\\MacIntel");
        var installDir  = p("INSTALL_DIR",  "C:\\Program Files\\MacIntel");
        var logDir      = p("LOG_DIR",      dataDir + "\\logs");
        var securityDir = p("SECURITY_DIR", dataDir + "\\security");
        var managerUrl  = p("MANAGER_URL",  "https://localhost:8443");
        var enrollToken = p("ENROLL_TOKEN", "");
        var apiKey      = p("MANAGER_API_KEY", "");
        var tlsVerify   = p("TLS_VERIFY",   "true");

        // Normalize path separators to forward-slashes inside TOML strings
        function toFwd(s) { return s.replace(/\\/g, "/"); }

        var keystoreType = "dpapi";   // default: DPAPI-backed file

        var toml = [
            "# agent.toml — mac_intel Agent Configuration",
            "# Generated by MSI installer on " + (new Date()).toISOString(),
            "# Edit this file to change agent behaviour; restart service to apply.",
            "",
            "[agent]",
            'id   = "' + agentId   + '"',
            'name = "' + agentName + '"',
            "",
            "[manager]",
            'url       = "' + managerUrl + '"',
            'tls_verify = ' + (tlsVerify.toLowerCase() === "false" ? "false" : "true"),
            'timeout_sec    = 30',
            'max_queue_size = 500',
        ];

        // Only write api_key if explicitly provided (skips enrollment)
        if (apiKey && apiKey.length === 64) {
            toml.push('api_key = "' + apiKey + '"');
        }

        toml = toml.concat([
            "",
            "[enrollment]",
            'token    = "' + enrollToken + '"',
            'keystore = "' + keystoreType + '"',
            "",
            "[watchdog]",
            "enabled              = true",
            "check_interval_sec   = 30",
            "max_restarts         = 5",
            "restart_window_sec   = 300",
            "",
            "[paths]",
            'install_dir  = "' + toFwd(installDir)  + '"',
            'config_dir   = "' + toFwd(dataDir)     + '"',
            'log_dir      = "' + toFwd(logDir)      + '"',
            'data_dir     = "' + toFwd(dataDir + "\\data") + '"',
            'security_dir = "' + toFwd(securityDir) + '"',
            'pid_file     = "' + toFwd(dataDir + "\\agent.pid") + '"',
            "",
            "[binaries]",
            'agent    = "' + toFwd(installDir + "\\bin\\macintel-agent.exe") + '"',
            'watchdog = "' + toFwd(installDir + "\\bin\\macintel-watchdog.exe") + '"',
            "",
            "[logging]",
            'level   = "INFO"',
            'file    = "' + toFwd(logDir + "\\agent.log") + '"',
            'max_mb  = 10',
            'backups = 3',
            "",
            "[collection]",
            "tick_sec = 5",
            "",
            "[collection.sections]",
            "",
            "[collection.sections.metrics]",
            "enabled      = true",
            "interval_sec = 60",
            "send         = true",
            "",
            "[collection.sections.connections]",
            "enabled      = true",
            "interval_sec = 60",
            "send         = true",
            "",
            "[collection.sections.processes]",
            "enabled      = true",
            "interval_sec = 60",
            "send         = true",
            "",
            "[collection.sections.ports]",
            "enabled      = true",
            "interval_sec = 60",
            "send         = true",
            "",
            "[collection.sections.network]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.arp]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.mounts]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.battery]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.open_files]",
            "enabled      = true",
            "interval_sec = 120",
            "send         = true",
            "",
            "[collection.sections.services]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.users]",
            "enabled      = true",
            "interval_sec = 600",
            "send         = true",
            "",
            "[collection.sections.hardware]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.containers]",
            "enabled      = true",
            "interval_sec = 120",
            "send         = true",
            "",
            "[collection.sections.security]",
            "enabled      = true",
            "interval_sec = 600",
            "send         = true",
            "",
            "[collection.sections.sysctl]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.configs]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.storage]",
            "enabled      = true",
            "interval_sec = 300",
            "send         = true",
            "",
            "[collection.sections.tasks]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.apps]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.packages]",
            "enabled      = true",
            "interval_sec = 3600",
            "send         = true",
            "",
            "[collection.sections.binaries]",
            "enabled      = true",
            "interval_sec = 86400",
            "send         = true",
            "",
            "[collection.sections.sbom]",
            "enabled      = true",
            "interval_sec = 86400",
            "send         = true",
        ]);

        var configPath = dataDir + "\\agent.toml";
        var fso = new ActiveXObject("Scripting.FileSystemObject");

        // Ensure data directory exists
        if (!fso.FolderExists(dataDir)) {
            fso.CreateFolder(dataDir);
        }

        var f = fso.CreateTextFile(configPath, true, false);  // overwrite, ASCII
        f.Write(toml.join("\r\n") + "\r\n");
        f.Close();
      ]]>
    </CustomAction>

    <!--
      CA: Restrict ACLs on the security directory after install.
      Uses icacls to deny Everyone and grant only SYSTEM + Administrators.
    -->
    <SetProperty
      Id="CA_SecureAcl"
      Value="&quot;[SystemFolder]icacls.exe&quot; &quot;[DATADIR]security&quot; /inheritance:r /grant:r &quot;NT AUTHORITY\SYSTEM:(OI)(CI)F&quot; /grant:r &quot;BUILTIN\Administrators:(OI)(CI)F&quot;"
      Sequence="execute"
      Before="CA_SecureAcl_Deferred" />

    <CustomAction
      Id="CA_SecureAcl_Deferred"
      Property="CA_SecureAcl"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <!--
      CA: Remove agent.toml and security dir on uninstall
      (WiX RemoveFile only handles files installed by the MSI)
    -->
    <CustomAction
      Id="CA_Cleanup_Deferred"
      Script="jscript"
      Execute="deferred"
      Return="ignore"
      Impersonate="no">
      <![CDATA[
        var data = Session.Property("CustomActionData");
        var props = {};
        data.split(";").forEach(function(pair) {
            var idx = pair.indexOf("=");
            if (idx > 0) props[pair.slice(0, idx)] = pair.slice(idx + 1);
        });
        var dataDir = props["DATA_DIR"] || "C:\\ProgramData\\MacIntel";
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        // Remove agent.toml
        var cfg = dataDir + "\\agent.toml";
        if (fso.FileExists(cfg)) { try { fso.DeleteFile(cfg, true); } catch(e){} }
        // Remove key files in security dir (plain + dpapi)
        var sec = dataDir + "\\security";
        if (fso.FolderExists(sec)) {
            try { fso.DeleteFolder(sec, true); } catch(e){}
        }
        // Remove logs
        var logs = dataDir + "\\logs";
        if (fso.FolderExists(logs)) {
            try { fso.DeleteFolder(logs, true); } catch(e){}
        }
        // Remove data dir if empty
        if (fso.FolderExists(dataDir)) {
            try { fso.DeleteFolder(dataDir, true); } catch(e){}
        }
      ]]>
    </CustomAction>

    <SetProperty
      Id="CA_Cleanup_Deferred"
      Value="DATA_DIR=[DATADIR]"
      Sequence="execute"
      Before="CA_Cleanup_Deferred" />

    <!-- ════════════════════════════════════════════════════════════════════
         Sequence: install
         ════════════════════════════════════════════════════════════════════ -->
    <InstallExecuteSequence>
      <!-- Write config after files are installed but before services start -->
      <Custom Action="CA_WriteConfig_Deferred"
              After="InstallFiles"
              Condition="NOT Installed" />

      <!-- Restrict ACL on security dir -->
      <Custom Action="CA_SecureAcl_Deferred"
              After="CA_WriteConfig_Deferred"
              Condition="NOT Installed" />

      <!-- Clean up config/keys on uninstall -->
      <Custom Action="CA_Cleanup_Deferred"
              Before="RemoveFiles"
              Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- ════════════════════════════════════════════════════════════════════
         UI: minimal dialog for interactive installs
         (silent /qn installs skip this entirely)
         ════════════════════════════════════════════════════════════════════ -->
    <UI>
      <UIRef Id="WixUI_Minimal" />
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchApplication"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <!-- Accept EULA automatically for silent installs -->
    <Property Id="LicenseAccepted" Value="1" />

  </Package>
</Wix>
