<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>AttackLens Agent 2.0.0</title>
    <organization>com.attacklens</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <allowed-os-versions>
        <os-version min="13.0"/>
    </allowed-os-versions>
    <pkg-ref id="com.attacklens.agent"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.attacklens.agent"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.attacklens.agent" visible="false">
        <pkg-ref id="com.attacklens.agent"/>
    </choice>
    <pkg-ref id="com.attacklens.agent" version="2.0.0" onConclusion="none">attacklens-component.pkg</pkg-ref>
</installer-gui-script>
