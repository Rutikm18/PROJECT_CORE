# =============================================================================
#  AttackLens Agent — Complete Configuration Reference
#
#  QUICK START (two required fields):
#    1. [manager] url  → your manager's address
#    2. [agent] name   → friendly label on dashboard
#
#  Generated by:  sudo bash install.sh --manager-url http://YOUR_IP:8080
#  Hot reload:    sudo attacklens-ctl reload   (SIGHUP — no restart needed)
#
#  INSTALLATION PATHS
#  ─────────────────────────────────────────────────────────────────────────
#  /Library/AttackLens/
#    bin/            ← attacklens-agent, attacklens-watchdog
#    agent.toml      ← this file  (root:wheel, mode 640)
#    security/       ← API key    (mode 700, managed by enrollment)
#    data/           ← in-flight telemetry queue
#    spool/          ← offline send queue (NDJSON+gzip, auto-drains on reconnect)
#    logs/           ← agent.log, watchdog.log (rotating)
#  /Library/LaunchDaemons/
#    com.attacklens.agent.plist
#    com.attacklens.watchdog.plist
#
#  SERVICE MANAGEMENT
#  ─────────────────────────────────────────────────────────────────────────
#  sudo attacklens-ctl status   → agent + watchdog status
#  sudo attacklens-ctl start    → start both services
#  sudo attacklens-ctl stop     → stop both services
#  sudo attacklens-ctl restart  → stop + start
#  sudo attacklens-ctl reload   → SIGHUP (hot config reload, no restart)
#  sudo attacklens-ctl logs     → tail live agent log
#  sudo attacklens-ctl enroll   → force re-enrollment (clears stored key)
#
#  SECURITY MODEL
#  ─────────────────────────────────────────────────────────────────────────
#  • API key auto-generated at enrollment → stored in macOS System Keychain
#    (keychain service: com.attacklens.agent)
#  • Payloads: gzip → AES-256-GCM (96-bit nonce) → HMAC-SHA256, over TLS 1.3
#  • Replay window: ±300 s timestamp check + 96-bit nonce dedup
#  • Key never written to this file after enrollment; use enrollment flow only
#  • tls_verify = false only for self-signed / dev setups
# =============================================================================


# ── Agent identity ────────────────────────────────────────────────────────────
[agent]
id          = ""                  # auto-derived from hardware UUID on first run (mac-<uuid>)
                                  # do NOT change after enrollment — breaks key lookup
name        = ""                  # friendly label shown on dashboard (default: ComputerName)
description = ""                  # optional longer description (team, location, role)
tags        = []                  # free-form labels e.g. ["prod", "finance", "laptop"]


# ── Manager connection ────────────────────────────────────────────────────────
# Use http:// for direct port 8080 access (trusted network / VPN / EC2 SG)
# Use https:// when Caddy TLS is configured (production deployment)
[manager]
url             = "http://YOUR_MANAGER_IP:8080"
tls_verify      = true            # set false only with self-signed certs (dev)
timeout_sec     = 30              # per-request timeout (seconds)
retry_attempts  = 3               # retries before spooling payload to disk
retry_delay_sec = 5               # base retry delay; doubles on each attempt (exp backoff)
max_queue_size  = 1000            # in-memory queue depth before back-pressure (drop oldest)
# api_key = ""                    # DO NOT SET — managed by enrollment flow + Keychain


# ── Enrollment ────────────────────────────────────────────────────────────────
# First-run registration only.  After enrollment the API key is stored in Keychain
# and this section is no longer used for normal operation.
[enrollment]
token    = ""                     # leave empty if manager has OPEN_ENROLLMENT=true
                                  # set to sk-enroll-xxx token if manager requires it
keystore = "keychain"             # "keychain" (macOS System Keychain, recommended)
                                  # "file"     (fallback: /Library/AttackLens/security/.key)


# ── Watchdog ──────────────────────────────────────────────────────────────────
# launchd → attacklens-watchdog → attacklens-agent
# The watchdog restarts the agent on crash and enforces a restart rate limit.
[watchdog]
enabled            = true
check_interval_sec = 30           # polling interval (seconds)
max_restarts       = 5            # max crashes within restart_window_sec before giving up
restart_window_sec = 300          # sliding window for restart counting (5 min)


# ── Filesystem paths ─────────────────────────────────────────────────────────
# Set by installer — only change if you customised installation paths.
[paths]
install_dir  = "/Library/AttackLens"
config_dir   = "/Library/AttackLens"
log_dir      = "/Library/AttackLens/logs"
data_dir     = "/Library/AttackLens/data"
security_dir = "/Library/AttackLens/security"
spool_dir    = "/Library/AttackLens/spool"
pid_file     = "/Library/AttackLens/attacklens-agent.pid"

[binaries]
agent    = "/Library/AttackLens/bin/attacklens-agent"
watchdog = "/Library/AttackLens/bin/attacklens-watchdog"


# ── Collection schedule ───────────────────────────────────────────────────────
# Global orchestrator settings.
# Per-section overrides go in the [collection.sections.*] blocks below.
#
# Circuit breakers: 3 consecutive failures → OPEN (section skipped)
#                   60 s cooldown → HALF-OPEN (probe)
#                   probe success → CLOSED (resumed)
[collection]
enabled  = true
tick_sec = 5                      # orchestrator pulse (how often to check section timers)

# Thread pool for concurrent section execution.
# Default: max(4, number_of_sections).  Tune lower on low-power devices.
worker_threads = 0                # 0 = auto (recommended)


# ══════════════════════════════════════════════════════════════════════════════
#  VOLATILE SECTIONS  — 10 s interval (high-frequency runtime state)
# ══════════════════════════════════════════════════════════════════════════════

# CPU %, memory %, swap, load averages, disk I/O rates, network I/O rates
# Fields sent: cpu_percent, mem_percent, cpu_per_core[], cpu_cores,
#              cpu_freq_mhz, mem_used_mb, mem_total_mb, mem_available_mb,
#              swap_percent, swap_used_mb, swap_total_mb,
#              disk_read_mb_s, disk_write_mb_s, net_sent_mb_s, net_recv_mb_s,
#              load_1m, load_5m, load_15m, uptime_sec
[collection.sections.metrics]
enabled      = true
interval_sec = 10
send         = true

# Active TCP/UDP connections with remote endpoints, process owner, and
# private/public IP classification.
# Fields sent: proto, local_addr, local_port, remote_addr, remote_port,
#              remote_service, state, pid, process, user, is_private, direction
[collection.sections.connections]
enabled      = true
interval_sec = 10
send         = true

# Running process list (top 80 by CPU) with signing status.
# Fields sent: pid, ppid, name, user, cpu_percent, mem_percent, mem_rss_mb,
#              mem_vms_mb, status, started_at, cmdline (512 chars), exe, signed
[collection.sections.processes]
enabled      = true
interval_sec = 10
send         = true
# Tune: reduce top-N to lower payload size on constrained endpoints
max_processes = 80


# ══════════════════════════════════════════════════════════════════════════════
#  NETWORK SECTIONS  — 30 s – 2 min
# ══════════════════════════════════════════════════════════════════════════════

# All LISTEN sockets (attack surface map).
# Fields sent: proto, port, bind_addr, state, pid, process
[collection.sections.ports]
enabled      = true
interval_sec = 30
send         = true

# Network interfaces (IPs, MACs, MTU), DNS servers, default gateway, WiFi info.
# Fields sent: interfaces[], dns_servers[], default_gw, hostname, domain,
#              wifi_ssid, wifi_bssid, wifi_rssi, wifi_channel
[collection.sections.network]
enabled      = true
interval_sec = 120
send         = true

# ARP table — local LAN neighbours (lateral movement detection).
# Fields sent: ip, mac, interface, state
[collection.sections.arp]
enabled      = true
interval_sec = 120
send         = true

# Mounted filesystems — device, mountpoint, fstype, options.
[collection.sections.mounts]
enabled      = true
interval_sec = 120
send         = true


# ══════════════════════════════════════════════════════════════════════════════
#  SYSTEM STATE SECTIONS  — 2 min
# ══════════════════════════════════════════════════════════════════════════════

# Battery state — charge %, cycle count, condition, power source.
# No-op on desktop Macs (present = false returned).
[collection.sections.battery]
enabled      = true
interval_sec = 120
send         = true

# Top 60 processes by open file descriptor count (anomaly/leak detection).
[collection.sections.openfiles]
enabled      = true
interval_sec = 120
send         = true
max_processes = 60

# LaunchDaemons and LaunchAgents — persistence mechanism visibility.
# Fields sent: name, status (running/stopped), enabled, pid, type, description
[collection.sections.services]
enabled      = true
interval_sec = 120
send         = true

# Local accounts, admin group members, last login timestamps.
# Fields sent: name, uid, gid, admin, locked, home, last_login
[collection.sections.users]
enabled      = true
interval_sec = 120
send         = true

# Hardware peripherals: USB, Thunderbolt, Bluetooth, GPU, SoC info.
# Fields sent per device: bus, name, vendor, product_id, vendor_id, serial, revision
[collection.sections.hardware]
enabled      = true
interval_sec = 120
send         = true

# Running containers (Docker, Podman).
# Fields sent: id, name, image, status, runtime, ports, created_at
[collection.sections.containers]
enabled      = true
interval_sec = 120
send         = true


# ══════════════════════════════════════════════════════════════════════════════
#  STORAGE INVENTORY  — 10 min
# ══════════════════════════════════════════════════════════════════════════════

# Disk volumes — device, mountpoint, fstype, total/used/free GB, usage %.
[collection.sections.storage]
enabled      = true
interval_sec = 600
send         = true

# Scheduled tasks — crontab entries and launchd periodic timers (persistence).
# Fields sent: name, type (cron|launchd), schedule, command, user, enabled,
#              last_run, next_run
[collection.sections.tasks]
enabled      = true
interval_sec = 600
send         = true


# ══════════════════════════════════════════════════════════════════════════════
#  SECURITY POSTURE  — 1 hr
# ══════════════════════════════════════════════════════════════════════════════

# macOS security posture: SIP, Gatekeeper, FileVault, Firewall, XProtect,
# Secure Boot, auto-update, Developer Tools mode, Lockdown Mode.
[collection.sections.security]
enabled      = true
interval_sec = 3600
send         = true

# Security-relevant kernel parameters (sysctl -a filtered to security prefixes).
# Fields sent: key, value, security_relevant
[collection.sections.sysctl]
enabled      = true
interval_sec = 3600
send         = true

# Critical config file content + hash:
#   ~/.zshrc, ~/.bashrc, ~/.ssh/config, ~/.ssh/authorized_keys,
#   /etc/hosts, /etc/ssh/sshd_config, /etc/sudoers
# Suspicious pattern detection (curl|bash, eval base64, etc.)
# Content capped at 4 KiB per file — never dumps full shell history.
[collection.sections.configs]
enabled      = true
interval_sec = 3600
send         = true


# ══════════════════════════════════════════════════════════════════════════════
#  SOFTWARE INVENTORY  — 24 hr
# ══════════════════════════════════════════════════════════════════════════════

# Installed .app bundles from /Applications, /System/Applications, ~/Applications.
# Fields sent: name, version, bundle_id, path, vendor, signed, notarized, installed_at
[collection.sections.apps]
enabled      = true
interval_sec = 86400
send         = true

# Package managers: brew (formulae + casks), pip3, npm -g, gem, cargo.
# Fields sent: manager, name, version, latest, outdated, installed_at
[collection.sections.packages]
enabled      = true
interval_sec = 86400
send         = true

# Filesystem binary scan — SHA-256 of executables in key PATH directories.
# Disabled by default: can be noisy and slow on large systems.
# Directories scanned: /usr/bin, /usr/local/bin, /opt/homebrew/bin, /usr/sbin, /bin, /sbin
# Fields sent: path, name, hash_sha256, size_bytes, permissions, suid, sgid, world_writable
[collection.sections.binaries]
enabled      = false              # enable with caution — slow on large systems
interval_sec = 86400
send         = false

# Software Bill of Materials — pip3, brew, npm, gem packages in PURL format.
# Fields sent: type, name, version, purl, license, source, cpe
[collection.sections.sbom]
enabled      = true
interval_sec = 86400
send         = true


# ── Agent health heartbeat (diagnostic, non-configurable) ─────────────────────
# Synthetic section emitted every 60 s by the orchestrator itself.
# Contains circuit-breaker state snapshot, queue depth, and uptime.
# NOT collected by a user-configurable collector — always enabled.
# [collection.sections.agent_health]   ← read-only, do not add this block


# ── Logging ───────────────────────────────────────────────────────────────────
[logging]
level   = "INFO"                          # DEBUG | INFO | WARNING | ERROR
file    = "/Library/AttackLens/logs/agent.log"
max_mb  = 10                              # rotate at this file size
backups = 5                               # keep N rotated log files
