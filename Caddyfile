# =============================================================================
#  Caddyfile — Reverse proxy for Jarvis Manager
#
#  Caddy automatically obtains and renews TLS certs from Let's Encrypt.
#  Used with docker-compose.prod.yml.
# =============================================================================

{env.DOMAIN} {
    # Auto-provision Let's Encrypt TLS cert
    tls {env.ADMIN_EMAIL}

    # Forward all traffic to the manager container
    reverse_proxy manager:8080

    # Log access
    log {
        output stdout
        format console
    }
}
